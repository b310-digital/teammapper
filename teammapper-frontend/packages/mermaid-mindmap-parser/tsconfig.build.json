{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "moduleResolution": "bundler",
    "rootDir": "./src"
  },
  "exclude": ["**/*.test.ts", "**/*.spec.ts", "dist"]
}
